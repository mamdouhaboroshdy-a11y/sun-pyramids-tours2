# =============================================================
# Sun Pyramids Tours - Environment Variables
# =============================================================
# NONE of these are required to run or deploy the app.
# The frontend reads its data directly from Firebase (config is
# bundled in firebase-applet-config.json), and the Express API
# falls back to built-in demo data when no database is set.
# -------------------------------------------------------------

# PORT (optional): The port the server listens on.
# On Railway this is injected automatically — do NOT set it manually.
# PORT=3000

# DATABASE_URL (optional): PostgreSQL connection string.
# Only needed if you want the Express API to persist to Postgres
# instead of returning the built-in demo data. If unset, the app
# still works using graceful fallbacks.
# DATABASE_URL="postgres://user:password@host:5432/dbname"

# GEMINI_API_KEY (optional): Google AI (Gemini) API key used to translate
# dynamic tour content (titles, descriptions, locations...) into the
# selected language (Russian / Italian / Arabic). Get a free key at
# https://aistudio.google.com/apikey
# If unset, the UI is still fully translated via built-in dictionaries and
# dynamic tour text simply stays in its source language.
# GEMINI_API_KEY="your-google-ai-studio-key"
